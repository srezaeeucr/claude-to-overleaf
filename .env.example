# Copy to .env and fill in. Never commit .env.

# Overleaf personal access token (Account Settings → Git Integration). Starts with olp_.
OVERLEAF_TOKEN=olp_replace_me

# Hex id from the Overleaf project's git URL (https://git.overleaf.com/<this-part>).
OVERLEAF_PROJECT_ID=replace_with_hex_id

# Absolute path to the local git repo whose root IS the LaTeX project.
REPO_PATH=/Users/saeedrezaee/Documents/Projects/your-latex-repo

# Optional — defaults shown.
# OVERLEAF_BRANCH=master
# OVERLEAF_REMOTE=overleaf
